.cache/
tmp/
temp/
*.tmp
*.cache

# Local server artifacts
xampp/
htdocs/
httpd.conf
php.ini
my.ini

# User uploads generated at runtime
public/uploads/*
!public/uploads/.gitkeep

# Database dumps/backups
database/dumps/
*.dump
*.bak.sql
*.backup.sql
*.sql.gz
*.zip
*.tar
*.tar.gz

